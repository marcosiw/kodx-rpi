# Copie para .envrc (não versionado) e ajuste os valores para o seu ambiente local.
# direnv: https://direnv.net/
#
# Usado ao rodar via terminal (dotnet run, scripts, docker). Se for debugar
# pela IDE (Visual Studio/Rider), que não herda o shell do direnv, copie
# src/Kodx.Rpi.Api/Properties/launchSettings.json.example para launchSettings.json
# e repita os mesmos valores lá — é o mesmo mecanismo (variáveis de ambiente),
# só entregue por um caminho diferente.

export ASPNETCORE_ENVIRONMENT=Development

# Portas gRPC (8080) e /health (8081) já vêm com default em appsettings.json (Kestrel:Endpoints).
# Só defina as variáveis abaixo se quiser sobrescrever localmente:
# export Kestrel__Endpoints__Grpc__Url=http://localhost:8080
# export Kestrel__Endpoints__Health__Url=http://localhost:8081

# Chave de API exigida no header X-Api-Key pelas requisições ao serviço.
export ApiKey__Value=local-dev-key

# Postgres local (docker-compose.yml na raiz do repo: docker compose up -d)
export ConnectionStrings__Postgres="Host=localhost;Port=5432;Database=kodx_rpi;Username=postgres;Password=postgres"

# Azure Blob Storage (container "rpi", mesmo formato do backup do legado).
export BlobStorage__ConnectionString=
